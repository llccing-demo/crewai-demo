# ================================================================
# Blog Improver - Environment Variables
# Copy this file to .env and fill in your API keys.
# ================================================================

# --- LLM (choose one) ---

# Option A: UniAPI + DeepSeek V4 Pro (OpenAI-compatible)
# Fill in your UniAPI key below.
OPENAI_API_KEY=your-uniapi-key-here
OPENAI_API_BASE=https://api.uniapi.io/v1
OPENAI_MODEL_NAME=deepseek-v4-pro

# Option B: OpenAI
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_MODEL_NAME=gpt-4o

# Option C: Ollama (free, runs locally)
# Install Ollama: https://ollama.com -> then run: ollama pull llama3.2
# Uncomment the lines below and comment out OPENAI_API_KEY above:
# OPENAI_API_BASE=http://localhost:11434/v1
# OPENAI_API_KEY=ollama          # any non-empty string
# OPENAI_MODEL_NAME=ollama/llama3.2

# --- Web Search (for Crew 1 trend research) ---
# Get free key at: https://serper.dev (2,500 free queries)
SERPER_API_KEY=your-serper-api-key-here
